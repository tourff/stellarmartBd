# Email Configuration (Copy to .env.local and fill your details)
# For Gmail: Enable 2FA, create App Password at https://myaccount.google.com/apppasswords
# For testing: Use Mailtrap (https://mailtrap.io) sandbox SMTP

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
FROM_EMAIL=StellarMartBD <your-email@gmail.com>

# Or Mailtrap example:
# EMAIL_HOST=smtp.mailtrap.io
# EMAIL_PORT=587  
# EMAIL_USER=your-mailtrap-username
# EMAIL_PASS=your-mailtrap-password
# FROM_EMAIL=no-reply@stellarmartbd.com

# Existing DB (keep)
MONGODB_URI=your-mongodb-connection-string
JWT_SECRET=stellarmartbd_secret_key_2024

